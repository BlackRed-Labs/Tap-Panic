            <ui:Label text="Score Points" style="width: 692px; height: 128px; position: absolute; left: 155px; -unity-text-align: middle-left; white-space: pre-wrap; font-size: 49px; -unity-font-style: normal; -unity-font-definition: resource(&quot;FlatSkin/Font/Roboto-Bold&quot;);"/>
        </ui:GroupBox>
