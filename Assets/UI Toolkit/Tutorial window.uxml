            <ui:Image name="Nuber" style="height: 100px; width: 100px; position: absolute; top: 46px; left: 27px; font-size: 40px; -unity-font-style: bold; -unity-font-definition: resource(&quot;FlatSkin/Font/Roboto-Bold&quot;); border-left-color: rgb(172, 112, 255); border-right-color: rgb(172, 112, 255); border-top-color: rgb(172, 112, 255); border-bottom-color: rgb(172, 112, 255); background-color: rgb(172, 112, 255); border-top-left-radius: 46px; border-top-right-radius: 46px; border-bottom-right-radius: 46px; border-bottom-left-radius: 46px;">
                <ui:Label text="3" name="Number" style="-unity-text-align: upper-center; height: 94px; font-size: 60px; color: rgb(255, 255, 255);"/>
            </ui:Image>
            <ui:Label text="Tapping outside loses LIFE " style="width: 692px; height: 128px; position: absolute; left: 155px; -unity-text-align: middle-left; white-space: pre-wrap; font-size: 49px; -unity-font-style: normal; -unity-font-definition: resource(&quot;FlatSkin/Font/Roboto-Bold&quot;);"/>
        </ui:GroupBox>
        <ui:GroupBox name="4" style="height: 184px; position: absolute; width: 853px; top: 727px; left: -1px; flex-direction: column-reverse; align-items: flex-start; justify-content: center; align-self: center;">
