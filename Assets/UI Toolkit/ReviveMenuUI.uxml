        <ui:Image name="Window" style="position: absolute; height: 924px; width: 806px; top: 748px; left: 131px; background-color: rgba(0, 0, 0, 0); background-image: url(&quot;project://database/Assets/Sprites/Revive%20Window.png?fileID=2800000&amp;guid=dfc9e9405c3344841ae2c1b2a62d9268&amp;type=3#Revive Window&quot;); border-top-left-radius: 0; border-top-right-radius: 0; border-bottom-right-radius: 0; border-bottom-left-radius: 0; border-left-color: rgba(255, 255, 255, 0); border-right-color: rgba(255, 255, 255, 0); border-top-color: rgba(255, 255, 255, 0); border-bottom-color: rgba(255, 255, 255, 0); border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0;">
            <ui:Label text="Revive?" name="ReviveText" style="position: absolute; height: 143px; width: 341px; left: 226px; font-size: 90px; -unity-text-align: middle-center; -unity-font-definition: url(&quot;project://database/Assets/300Mind/2D%20Game%20UI%20Kit/Fonts/Oswald-SemiBold.ttf?fileID=12800000&amp;guid=197aa00286a04c4449aa64092ddff51c&amp;type=3#Oswald-SemiBold&quot;); -unity-font-style: bold; text-shadow: 0 0 0 rgb(0, 0, 0); -unity-text-outline-color: rgb(0, 0, 0); color: rgb(255, 255, 255); -unity-text-outline-width: 1px; display: flex; -unity-text-auto-size: best-fit 10px 100px; -unity-text-generator: advanced;"/>
            <ui:GroupBox name="Ads" style="display: none;">
                <ui:Image name="AdImage" style="position: absolute; height: 124px; width: 153px; top: 250px; left: 324px; background-image: url(&quot;project://database/Assets/Sprites/video.png?fileID=2800000&amp;guid=bec35a5de0289f3478e89326a29947d4&amp;type=3#video&quot;);"/>
                <ui:Label text="Watch an ad to revive and continue your game!" enabled="true" name="AdText" style="position: absolute; height: 143px; width: 598px; top: 468px; left: 110px; font-size: 47px; white-space: pre-wrap; -unity-text-align: middle-center; -unity-font-style: bold; -unity-font-definition: url(&quot;project://database/Assets/300Mind/2D%20Game%20UI%20Kit/Fonts/Oswald-SemiBold.ttf?fileID=12800000&amp;guid=197aa00286a04c4449aa64092ddff51c&amp;type=3#Oswald-SemiBold&quot;); display: flex; visibility: visible; color: rgb(255, 255, 255);"/>
