            <ui:Label text="50" name="Price" enabled="true" style="position: absolute; height: 117px; width: 332px; top: 263px; left: 376px; font-size: 116px; -unity-font-definition: url(&quot;project://database/Assets/300Mind/2D%20Game%20UI%20Kit/Fonts/GROBOLD.ttf?fileID=12800000&amp;guid=9c352b97d4c9f334c920e85edcd05523&amp;type=3#GROBOLD&quot;); -unity-text-align: middle-left; white-space: pre-wrap; color: rgb(255, 255, 255); -unity-font-style: normal; -unity-text-auto-size: best-fit 10px 100px; -unity-text-generator: advanced; -unity-text-outline-color: rgb(0, 0, 0); -unity-text-outline-width: 2px; display: flex;">
